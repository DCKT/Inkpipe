{
  "name": "inkpipe",
  "private": true,
  "version": "0.2.3",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/web",
    "packages/watcher"
  ],
  "scripts": {
    "dev": "concurrently -n server,web,watcher -c cyan,magenta,yellow \"bun run --filter @inkpipe/server dev\" \"bun run --filter @inkpipe/web dev\" \"bun run --filter @inkpipe/watcher dev\"",
    "build": "bun run --filter @inkpipe/web build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --filter '*' typecheck",
    "prepare": "effect-tsgo patch"
  },
  "devDependencies": {
    "@effect/tsgo": "0.14.3",
    "@types/web-push": "^3.6.4",
    "@typescript/native-preview": "latest",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "web-push": "^3.6.7"
  }
}
