{
  "name": "@inkpipe/shared",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./rpc": {
      "types": "./src/rpc/index.ts",
      "import": "./src/rpc/index.ts"
    },
    "./rpc/*": {
      "types": "./src/rpc/*.ts",
      "import": "./src/rpc/*.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/rpc": "^0.75.1",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
